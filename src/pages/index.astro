    .panel-key[data-panel-key='technologies']:hover .chip-pin-r, .panel-key[data-panel-key='technologies']:focus-visible .chip-pin-r, .panel-key[data-panel-key='technologies'][aria-pressed='true'] .chip-pin-r { animation: chip-pin .3s var(--ease-reveal) .4s both; }
    .panel-key[data-panel-key='technologies']:hover .chip-pin-b, .panel-key[data-panel-key='technologies']:focus-visible .chip-pin-b, .panel-key[data-panel-key='technologies'][aria-pressed='true'] .chip-pin-b { animation: chip-pin .3s var(--ease-reveal) .5s both; }
    .panel-key[data-panel-key='technologies']:hover .chip-pin-l, .panel-key[data-panel-key='technologies']:focus-visible .chip-pin-l, .panel-key[data-panel-key='technologies'][aria-pressed='true'] .chip-pin-l { animation: chip-pin .3s var(--ease-reveal) .6s both; }

