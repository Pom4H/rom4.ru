  .git-flow .is-live { color: #061923; background: #d7f0dd; border-color: #d7f0dd; }
  .git-flow .is-live span, .git-flow .is-live small, .git-flow .is-live em { color: #1f5a3a; }
  .trace-list { position: relative; z-index: 1; border-top: 1px solid rgba(219,229,225,.18); }
  .trace-list p { min-height: 40px; margin: 0; display: grid; grid-template-columns: 1fr auto 70px; align-items: center; gap: 18px; border-bottom: 1px solid rgba(219,229,225,.12); font: 8px/1 monospace; }
  .trace-list b { color: #9fafaa; font-weight: 400; }
  .trace-list i { color: #62bb7b; font-style: normal; text-align: right; }
  .console-metrics { position: absolute; z-index: 1; left: 25px; right: 25px; bottom: 20px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(219,229,225,.2); }
  .console-metrics span { padding: 12px; background: #0a222d; font: 7px/1.2 monospace; }
  .console-metrics b { display: block; margin-bottom: 5px; color: #fff; font-size: 14px; }

  .results { padding-bottom: 28px; }
  .results-intro { border-bottom: 0; }
  .result-grid { padding: 0 28px; display: grid; grid-template-columns: repeat(12, 1fr); gap: 18px; }
  .result-card { min-width: 0; min-height: 370px; padding: 26px; display: flex; flex-direction: column; overflow: hidden; border: 1px solid rgba(var(--ink-rgb),.35); background: rgba(244,242,234,.62); }
  .product-result { grid-column: span 7; }
  .modernization-result { grid-column: span 5; }
  .git-result, .context-result, .integration-result { grid-column: span 4; min-height: 405px; }
  .leadership-result { grid-column: span 12; min-height: 265px; display: grid; grid-template-columns: 1.3fr 1fr; grid-template-rows: auto auto 1fr; column-gap: 55px; }
  .result-heading { display: flex; justify-content: space-between; align-items: center; padding-bottom: 17px; border-bottom: 1px solid rgba(var(--ink-rgb),.2); }
  .result-heading span { color: var(--rust); font: 18px/1 'Times New Roman', serif; }
  .result-heading p { margin: 0; text-transform: uppercase; font: 7px/1 monospace; letter-spacing: .06em; }
  .result-card h3 { max-width: 530px; margin: 23px 0 0; font: 400 clamp(26px, 2.6vw, 40px)/1 'Times New Roman', serif; letter-spacing: -.025em; }
  .result-description { max-width: 550px; margin: 15px 0 22px; font-size: 10px; line-height: 1.58; }
  .result-outcome { margin-top: auto; padding-top: 15px; display: grid; grid-template-columns: 75px 1fr; gap: 12px; border-top: 1px solid rgba(var(--ink-rgb),.22); }
  .result-outcome span { color: var(--rust); font: 700 7px/1.35 monospace; }
  .result-outcome p { margin: 0; font-size: 9px; line-height: 1.5; }

  .result-ui { position: relative; width: min(100%, 470px); height: 160px; margin: 0 0 25px auto; display: grid; grid-template-columns: 53px 1fr; grid-template-rows: 24px 1fr 27px; border: 1px solid var(--ink); box-shadow: 7px 8px 0 rgba(var(--ink-rgb),.065); }
  .result-ui > div { grid-column: 1 / -1; padding: 0 7px; display: flex; align-items: center; gap: 5px; border-bottom: 1px solid rgba(var(--ink-rgb),.2); }
  .result-ui > div i { width: 5px; height: 5px; border: 1px solid; border-radius: 50%; }
  .result-ui aside { border-right: 1px solid rgba(var(--ink-rgb),.2); background: repeating-linear-gradient(var(--bar) 0 3px, transparent 3px 14px); background-size: 26px 14px; background-position: 12px 13px; }
  .result-ui section { padding: 18px; display: grid; gap: 8px; }
  .result-ui section span { display: block; height: 8px; background: var(--bar); }
  .result-ui section span:first-child { width: 46%; background: var(--blue); }
  .result-ui section span:nth-child(2) { width: 86%; }
  .result-ui section span:nth-child(3) { width: 68%; }
  .result-ui footer { grid-column: 1 / -1; padding: 0 9px; display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(var(--ink-rgb),.2); font: 7px/1 monospace; }
  .result-ui footer span { color: var(--pos); }

  .result-migration { margin: 24px 0; display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; align-items: center; gap: 8px; text-align: center; font: 8px/1 monospace; }
  .result-migration > span { padding: 17px 5px; border: 1px solid rgba(var(--ink-rgb),.38); }
  .result-migration > span:last-of-type { color: white; background: var(--blue); border-color: var(--blue); }
  .result-migration > i { font-style: normal; }
  .result-migration p { grid-column: 1 / -1; height: 5px; margin: 18px 0 0; background: var(--bar); text-align: left; }
  .result-migration p b { display: block; height: 100%; background: var(--rust); }
  .result-migration small { grid-column: 1 / -1; color: var(--muted); font-size: 7px; }
  .result-trace { margin-bottom: 23px; border-top: 1px solid rgba(var(--ink-rgb),.2); }
  .result-trace p { min-height: 35px; margin: 0; display: grid; grid-template-columns: 23px 1fr auto; align-items: center; border-bottom: 1px solid rgba(var(--ink-rgb),.16); font: 7px/1 monospace; }
  .result-trace span { color: var(--muted); }
  .result-trace b { color: var(--pos); font-weight: 400; }
  .result-context { margin-bottom: 21px; font: 7px/1 monospace; }
  .result-context label { height: 34px; padding: 0 9px; display: flex; align-items: center; justify-content: space-between; background: white; border: 1px solid rgba(var(--ink-rgb),.3); }
  .result-context p { margin: 0; padding: 12px 5px; display: flex; justify-content: space-between; border-bottom: 1px solid rgba(var(--ink-rgb),.16); }
  .result-context small { color: var(--muted); }
  .result-route { margin: 25px 0; display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr; gap: 5px; align-items: center; font: 7px/1 monospace; text-align: center; }
  .result-route span { padding: 16px 3px; border: 1px solid rgba(var(--ink-rgb),.35); }
  .result-route i { color: var(--muted); font-style: normal; }
  .result-route small { grid-column: 1 / -1; padding-top: 11px; color: var(--muted); border-top: 1px dotted rgba(var(--ink-rgb),.35); }
  .leadership-result .result-heading { grid-column: 1 / -1; }
  .leadership-result h3 { grid-column: 1; font-size: clamp(34px, 3vw, 48px); }
  .leadership-result .result-description { grid-column: 1; }
  .leadership-result .result-handoff { grid-column: 2; grid-row: 2 / 4; align-self: center; }
  .leadership-result .result-outcome { grid-column: 1; }
  .result-handoff { display: grid; grid-template-columns: repeat(2, 1fr); border: 1px solid rgba(var(--ink-rgb),.28); }
  .result-handoff span { min-height: 62px; padding: 13px; display: flex; justify-content: space-between; align-items: center; font: 8px/1 monospace; }
  .result-handoff span:nth-child(odd) { border-right: 1px solid rgba(var(--ink-rgb),.2); }
  .result-handoff span:nth-child(n+3) { border-top: 1px solid rgba(var(--ink-rgb),.2); }
  .result-handoff i { color: var(--pos); font-style: normal; }

  .method-intro { border-bottom: 1px solid rgba(var(--ink-rgb),.3); }
  .method-layout { display: grid; grid-template-columns: 41% 59%; }
  .method-manifesto { min-height: 620px; padding: 54px 52px; display: flex; flex-direction: column; justify-content: center; border-right: 1px solid rgba(var(--ink-rgb),.24); background: rgba(231,226,211,.38); }
  .method-manifesto > p:first-child { margin: 0 0 28px; color: var(--rust); font: 700 9px/1 monospace; letter-spacing: .06em; }
  .method-manifesto h3 { margin: 0; font: 400 clamp(43px, 4.3vw, 67px)/.9 'Iowan Old Style', 'Baskerville', 'Times New Roman', serif; letter-spacing: -.045em; }
  .method-manifesto > p:nth-of-type(2) { max-width: 430px; margin: 36px 0 0; font-size: 12px; line-height: 1.7; }
  .method-manifesto > div { margin-top: 45px; display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid rgba(var(--ink-rgb),.3); }
  .method-manifesto > div span { min-height: 43px; display: grid; place-items: center; font: 7px/1 monospace; }
  .method-manifesto > div span + span { border-left: 1px solid rgba(var(--ink-rgb),.2); }
  .method-track { display: grid; }
  .method-track article { min-height: 155px; padding: 27px 38px; display: grid; grid-template-columns: 66px 1fr auto; gap: 25px; align-items: center; }
  .method-track article + article { border-top: 1px solid rgba(var(--ink-rgb),.22); }
  .method-no { color: var(--muted); font: 39px/1 'Times New Roman', serif; }
  .method-track h3 { margin: 0 0 10px; font: 400 25px/1 'Times New Roman', serif; }
  .method-track p { max-width: 510px; margin: 0; font-size: 10px; line-height: 1.58; }
  .method-track article > b { min-width: 72px; padding: 8px; color: var(--blue); border: 1px solid color-mix(in srgb, var(--blue), transparent 62%); font: 700 7px/1 monospace; text-align: center; }

  .footer { display: grid; grid-template-columns: 1.7fr 1fr; min-height: 320px; border-bottom: 0; }
  .footer-primary { padding: 50px 44px; display: flex; flex-direction: column; }
  .footer-aside { padding: 48px 40px; border-left: 1px solid rgba(var(--ink-rgb),.2); display: flex; flex-direction: column; }
  .footer-manifesto { margin: 0; max-width: 570px; font: 400 clamp(27px, 2.7vw, 39px)/1.1 'Iowan Old Style', 'Baskerville', 'Times New Roman', serif; letter-spacing: -.025em; }
  .footer-cta-row { margin-top: 32px; display: flex; align-items: center; gap: 30px; flex-wrap: wrap; }
  .footer-cta-row .button { min-width: 236px; min-height: 52px; }
  .footer-links { display: flex; flex-direction: column; gap: 9px; }
  .footer-links a { color: var(--ink); font: 11px/1 monospace; text-decoration: underline; text-decoration-color: rgba(var(--ink-rgb),.32); text-underline-offset: 3px; transition: color .2s ease, text-decoration-color .2s ease; }
  .footer-links a:hover, .footer-links a:focus-visible { color: var(--rust); text-decoration-color: var(--rust); outline: none; }
  .footer-trust { margin: auto 0 0; padding-top: 30px; font: 9px/1.4 monospace; letter-spacing: .05em; color: var(--muted); }
  .footer-id .brand { display: block; font-size: 30px; }
  .footer-id p { margin: 15px 0 0; font: 9px/1.65 monospace; color: var(--muted); }
  .note-card { position: relative; align-self: start; margin: 32px 0 0; padding: 18px 20px 22px; background: #e8e4d9; box-shadow: 1px 3px 8px rgba(31,31,26,.09); transform: rotate(-1.2deg); }
  .note-card > span { font: 8px/1 monospace; letter-spacing: .06em; color: var(--muted); }
  .note-card > i { position: absolute; top: -9px; left: 50%; width: 43px; height: 17px; background: var(--rust); transform: translateX(-50%) rotate(-4deg); opacity: .85; }
  .note-card p { margin: 18px 0 0; max-width: 235px; font: italic 13px/1.42 'Bradley Hand', 'Iowan Old Style', cursive, serif; }

  .footer-bottom { grid-column: 1 / -1; min-height: 42px; padding: 13px 44px; display: grid; grid-template-columns: 1.6fr 1fr auto; align-items: center; gap: 20px; border-top: 1px solid rgba(var(--ink-rgb),.24); font: 7px/1.4 monospace; letter-spacing: .04em; }
  .footer-bottom a { display: inline-block; padding: 6px 2px; color: var(--ink); text-decoration: none; }

  /* ===== Reveal при скролле (кросс-браузерно, через IntersectionObserver) ===== */
  :global(html.js) .system-visual,
  :global(html.js) .section-intro,
  :global(html.js) .direction-card,
  :global(html.js) .result-card,
  :global(html.js) .method-manifesto,
  :global(html.js) .method-track article,
  :global(html.js) .footer > div,
  :global(html.js) .footer > aside {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity .8s var(--ease-reveal) calc(var(--reveal-i, 0) * 75ms),
                transform .8s var(--ease-reveal) calc(var(--reveal-i, 0) * 75ms),
                translate .3s var(--ease-snap), border-color .3s ease, box-shadow .3s ease;
  }
  :global(html.js) .system-visual { transform: translateY(28px) scale(.985); transform-origin: 60% 40%; }

  /* Хореография входа hero: заголовок → лид → кнопки */
  :global(html.js) .hero-copy > * { opacity: 0; animation: heroRise .9s var(--ease-reveal) both; }
  :global(html.js) .hero-copy > h1 { animation-delay: .08s; }
  :global(html.js) .hero-copy > .lead { animation-delay: .24s; }
  :global(html.js) .hero-copy > .hero-actions { animation-delay: .4s; }
  @keyframes heroRise { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }

  /* CI/CD-консоль: пайплайн «пробегает» при появлении */
  :global(html.js) .git-direction .git-flow > div,
  :global(html.js) .git-direction .git-flow > i,
  :global(html.js) .git-direction .trace-list p,
  :global(html.js) .git-direction .console-metrics span { opacity: 0; }
  .git-direction.is-in .git-flow > div { animation: pipeStage .46s var(--ease-reveal) both; }
  .git-direction.is-in .git-flow > i { animation: pipeArrow .36s var(--ease-reveal) both; }
  .git-direction.is-in .git-flow > div:nth-of-type(1) { animation-delay: .12s; }
  .git-direction.is-in .git-flow > i:nth-of-type(1) { animation-delay: .22s; }
  .git-direction.is-in .git-flow > div:nth-of-type(2) { animation-delay: .28s; }
  .git-direction.is-in .git-flow > i:nth-of-type(2) { animation-delay: .38s; }
  .git-direction.is-in .git-flow > div:nth-of-type(3) { animation-delay: .44s; }
  .git-direction.is-in .git-flow > i:nth-of-type(3) { animation-delay: .54s; }
  .git-direction.is-in .git-flow > div:nth-of-type(4) { animation-delay: .6s; }
  .git-direction.is-in .trace-list p { animation: pipeRow .4s var(--ease-reveal) both; }
  .git-direction.is-in .trace-list p:nth-child(1) { animation-delay: .68s; }
  .git-direction.is-in .trace-list p:nth-child(2) { animation-delay: .76s; }
  .git-direction.is-in .trace-list p:nth-child(3) { animation-delay: .84s; }
  .git-direction.is-in .trace-list p:nth-child(4) { animation-delay: .92s; }
  .git-direction.is-in .console-metrics span { animation: pipeStage .46s var(--ease-reveal) both; animation-delay: 1s; }
  @keyframes pipeStage { from { opacity: 0; transform: translateY(9px); } to { opacity: 1; transform: none; } }
  @keyframes pipeArrow { from { opacity: 0; transform: translateX(-4px); } to { opacity: 1; transform: none; } }
  @keyframes pipeRow { from { opacity: 0; transform: translateX(-7px); } to { opacity: 1; transform: none; } }

  /* Ховер карточек результатов (translate — независимо от reveal-transform) */
  .result-card { transition: translate .3s var(--ease-snap), border-color .3s ease, box-shadow .3s ease; }
  .result-card:hover {
    translate: 0 -4px;
    border-color: rgba(var(--ink-rgb),.5);
    box-shadow: 0 16px 34px rgba(var(--ink-rgb),.1);
  }
  .leadership-result:hover { translate: 0 -3px; }

  :global(html.js) .system-visual.is-in,
  :global(html.js) .section-intro.is-in,
  :global(html.js) .direction-card.is-in,
  :global(html.js) .result-card.is-in,
  :global(html.js) .method-manifesto.is-in,
  :global(html.js) .method-track article.is-in,
  :global(html.js) .footer > div.is-in,
  :global(html.js) .footer > aside.is-in {
    opacity: 1;
    transform: none;
  }

  @media (max-width: 1120px) {
    .topbar { padding-inline: 32px; gap: 20px; }
    .topbar nav { gap: 18px; }
    .hero-copy { padding-left: 48px; }
    h1 { font-size: 59px; }
    .section-intro { padding-inline: 38px; grid-template-columns: 1.8fr 4.5fr 3fr; gap: 30px; }
    .direction-card { grid-template-columns: 39% 61%; }
    .direction-copy { padding-inline: 38px; }
    .build-canvas, .migration-map, .git-console { margin-inline: 25px; }
    .map-conn { flex-basis: 22px; }
    .result-grid { padding-inline: 20px; }
    .result-card { padding: 22px; }
    .method-layout { grid-template-columns: 39% 61%; }
    .method-manifesto { padding-inline: 38px; }
    .method-track article { padding-inline: 28px; grid-template-columns: 56px 1fr auto; gap: 18px; }
    .footer-primary { padding: 40px 34px; }
    .footer-aside { padding: 40px 34px; }
    .footer-bottom { padding-inline: 34px; }
  }

