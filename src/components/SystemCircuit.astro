---
// ROM4.RU — интерактивный пульт (control panel). Разметка; логика и стили — в index.astro.
---
<section class="system-panel" data-system-panel data-active="product" aria-label="Интерактивный пульт цифровой системы">
  <div class="board-shell">
    <span class="side-label side-label-left">SOFTWARE ENGINEERING · DIGITAL PRODUCTS · 2026</span>
    <span class="side-label side-label-right">ЕДИНИЦА ИЗМЕРЕНИЯ — РАБОТАЮЩИЙ ПРОДУКТ</span>
    <span class="screw screw-a" aria-hidden="true"></span>
    <span class="screw screw-b" aria-hidden="true"></span>
    <span class="screw screw-c" aria-hidden="true"></span>
    <span class="screw screw-d" aria-hidden="true"></span>
    <div class="panel-grid" role="group" aria-label="Функции цифровой системы">
      <div class="panel-screen" data-panel-readout aria-live="polite">
        <div class="screen-head">
          <span class="readout-index" data-readout-index>01</span>
          <span class="readout-label" data-readout-label>Продукт</span>
          <span class="screen-dot" aria-hidden="true"></span>
        </div>
        <p class="readout-title" data-readout-title>Ценность собрана в продукт</p>
        <p class="readout-detail" data-readout-detail>Пользовательский сценарий, данные и бизнес-логика работают как одно целое.</p>
      </div>

      <button class="panel-key" type="button" data-panel-key="product" data-index="01" data-label="Продукт" data-title="Ценность собрана в продукт" data-detail="Пользовательский сценарий, данные и бизнес-логика работают как одно целое." data-accent="#bd5b31" aria-label="01. Продукт" aria-pressed="false" style="--key-accent: #bd5b31">
        <span class="key-number">01</span>
        <svg class="key-icon key-icon-cube" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-cube"><path class="cube-face cube-top" d="m13 22 19-10 19 10-19 10Z"></path><path class="cube-face cube-left" d="M13 22v21l19 10V32Z"></path><path class="cube-face cube-right" d="M51 22v21l-19 10V32Z"></path><path class="cube-seam" d="M32 32v21"></path></g></svg>
        <span class="key-label">Продукт</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="task" data-index="02" data-label="Задача" data-title="Команда понимает, что меняет" data-detail="Цель, эффект для пользователя и критерии готовности зафиксированы до разработки." data-accent="#164a76" aria-label="02. Задача" aria-pressed="false" style="--key-accent: #164a76">
        <span class="key-number">02</span>
        <svg class="key-icon key-icon-target" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-target"><circle class="target-ring target-ring-1" cx="32" cy="32" r="17"></circle><circle class="target-ring target-ring-2" cx="32" cy="32" r="8"></circle><circle class="target-dot" cx="32" cy="32" r="3" fill="currentColor" stroke="none"></circle><path class="target-tick target-tick-t" d="M32 9v10"></path><path class="target-tick target-tick-r" d="M55 32h-10"></path><path class="target-tick target-tick-b" d="M32 55v-10"></path><path class="target-tick target-tick-l" d="M9 32h10"></path></g></svg>
        <span class="key-label">Задача</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="prototype" data-index="03" data-label="Прототип" data-title="Гипотеза проверяется рано" data-detail="Рабочий прототип показывает ценность и ограничения до начала полноценной разработки." data-accent="#8f5e2f" aria-label="03. Прототип" aria-pressed="false" style="--key-accent: #8f5e2f">
        <span class="key-number">03</span>
        <svg class="key-icon key-icon-expand" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-expand"><rect class="expand-core" x="22" y="22" width="20" height="20" rx="2.5"></rect><path class="expand-a" d="M16 26V16h10"></path><path class="expand-b" d="M48 38v10H38"></path></g></svg>
        <span class="key-label">Прототип</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="code" data-index="04" data-label="Код" data-title="Решение становится кодом" data-detail="Типы, тесты и инженерные соглашения удерживают качество при развитии продукта." data-accent="#2f546f" aria-label="04. Код" aria-pressed="false" style="--key-accent: #2f546f">
        <span class="key-number">04</span>
        <svg class="key-icon key-icon-cli" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-cli"><rect class="cli-frame" x="10" y="14" width="44" height="36" rx="4"></rect><path class="cli-prompt" d="M18 28 L26 34 L18 40"></path><path class="cli-cursor" d="M30 40H42"></path></g></svg>
        <span class="key-label">Код</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="interface" data-index="05" data-label="Интерфейс" data-title="Интерфейс собирает продукт воедино" data-detail="Экраны, состояния и навигация связывают данные и логику в понятный пользователю сценарий." data-accent="#47704e" aria-label="05. Интерфейс" aria-pressed="false" style="--key-accent: #47704e">
        <span class="key-number">05</span>
        <svg class="key-icon key-icon-ui" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-ui"><rect class="ui-frame" x="10" y="14" width="44" height="36" rx="3"></rect><path class="ui-divider" d="M25 14v36"></path><circle class="ui-dot ui-dot-1" cx="17.5" cy="22" r="1.8" fill="currentColor" stroke="none"></circle><circle class="ui-dot ui-dot-2" cx="17.5" cy="30" r="1.8" fill="currentColor" stroke="none"></circle><path class="ui-block ui-block-1" d="M31 24h17"></path><path class="ui-block ui-block-2" d="M31 32h17"></path><path class="ui-block ui-block-3" d="M31 40h11"></path></g></svg>
        <span class="key-label">Интерфейс</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="design" data-index="06" data-label="Дизайн" data-title="Продукт выглядит и ощущается цельно" data-detail="Визуальный язык, типографика и состояния собраны в систему, а не рисуются заново на каждом экране." data-accent="#725e3c" aria-label="06. Дизайн" aria-pressed="false" style="--key-accent: #725e3c">
        <span class="key-number">06</span>
        <svg class="key-icon key-icon-shapes" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-shapes"><rect class="shape-sq" x="10" y="10" width="28" height="28" rx="2"></rect><circle class="shape-ci" cx="40" cy="40" r="14"></circle></g></svg>
        <span class="key-label">Дизайн</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="ai" data-index="07" data-label="AI" data-title="AI встроен там, где он полезен" data-detail="Модели решают задачу продукта — с контролем качества и стоимости." data-accent="#bd5b31" aria-label="07. AI" aria-pressed="false" style="--key-accent: #bd5b31">
        <span class="key-number">07</span>
        <svg class="key-icon key-icon-ai" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-ai"><path class="ai-spark ai-spark-main" d="M30 8 C 32 24 36 28 52 30 C 36 32 32 36 30 52 C 28 36 24 32 8 30 C 24 28 28 24 30 8 Z"></path><path class="ai-spark ai-spark-mini" d="M49 40 C 50 46 51 47 57 48 C 51 49 50 50 49 56 C 48 50 47 49 41 48 C 47 47 48 46 49 40 Z"></path></g></svg>
        <span class="key-label">AI</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="release" data-index="08" data-label="Релиз" data-title="Изменение дошло до пользователя" data-detail="Команда знает состав версии, её состояние и ожидаемый эффект для пользователя." data-accent="#164a76" aria-label="08. Релиз" aria-pressed="false" style="--key-accent: #164a76">
        <span class="key-number">08</span>
        <svg class="key-icon key-icon-chart" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-chart"><path d="M11 52h43M14 48V14"></path><path class="chart-line" pathLength="100" d="m17 42 10-11 8 7 13-18"></path><circle class="chart-point point-a" cx="27" cy="31" r="3"></circle><circle class="chart-point point-b" cx="35" cy="38" r="3"></circle><circle class="chart-point point-c" cx="48" cy="20" r="3"></circle><circle class="ping" cx="48" cy="20" r="3" fill="none"></circle></g></svg>
        <span class="key-label">Релиз</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="integration" data-index="09" data-label="Интеграции" data-title="Продукт встроен в бизнес" data-detail="Системы и данные связаны через ясные, документированные интерфейсы." data-accent="#47704e" aria-label="09. Интеграции" aria-pressed="false" style="--key-accent: #47704e">
        <span class="key-number">09</span>
        <svg class="key-icon key-icon-plug" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-plug"><path class="plug-left" d="M20 24H6v16h14M20 28h7M20 36h7"></path><path class="plug-right" d="M44 24h14v16H44M44 28h-7M44 36h-7"></path><path class="plug-spark" d="M32 28 33 31 36 32 33 33 32 36 31 33 28 32 31 31Z"></path></g></svg>
        <span class="key-label">Интеграции</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="monitoring" data-index="10" data-label="Мониторинг" data-title="Поведение продукта видно команде" data-detail="Метрики, ошибки и состояние выпущенной версии доступны без догадок и ручного расследования." data-accent="#76556f" aria-label="10. Мониторинг" aria-pressed="false" style="--key-accent: #76556f">
        <span class="key-number">10</span>
        <svg class="key-icon key-icon-pulse" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-pulse"><path class="pulse-line" d="M9 41 h16 l4 3 l4 -24 l4 24 l3 -3 h15"></path><circle class="pulse-ping" cx="33" cy="20" r="8"></circle></g></svg>
        <span class="key-label">Мониторинг</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="technologies" data-index="11" data-label="Технологии" data-title="Технологии выбраны под задачу" data-detail="Инструменты подобраны под задачу и ограничения, а не по моде, — и их сможет поддерживать команда." data-accent="#8f5e2f" aria-label="11. Технологии" aria-pressed="false" style="--key-accent: #8f5e2f">
        <span class="key-number">11</span>
        <svg class="key-icon key-icon-chip" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-chip"><rect class="chip-core" x="20" y="20" width="24" height="24" rx="3"></rect><rect class="chip-inner" x="28" y="28" width="8" height="8" rx="1.5"></rect><path class="chip-pin chip-pin-t" d="M26 20v-6M32 20v-6M38 20v-6"></path><path class="chip-pin chip-pin-b" d="M26 44v6M32 44v6M38 44v6"></path><path class="chip-pin chip-pin-l" d="M20 26h-6M20 32h-6M20 38h-6"></path><path class="chip-pin chip-pin-r" d="M44 26h6M44 32h6M44 38h6"></path></g></svg>
        <span class="key-label">Технологии</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>

      <button class="panel-key" type="button" data-panel-key="infrastructure" data-index="12" data-label="Инфраструктура" data-title="Среда, где продукт живёт" data-detail="Окружения, конфигурация и ресурсы описаны кодом и воспроизводятся без ручной настройки." data-accent="#6e7047" aria-label="12. Инфраструктура" aria-pressed="false" style="--key-accent: #6e7047">
        <span class="key-number">12</span>
        <svg class="key-icon key-icon-infra" viewBox="0 0 64 64" aria-hidden="true"><g class="icon-infra"><rect class="infra-unit infra-unit-1" x="13" y="14" width="38" height="11" rx="2.5"></rect><rect class="infra-unit infra-unit-2" x="13" y="27" width="38" height="11" rx="2.5"></rect><rect class="infra-unit infra-unit-3" x="13" y="40" width="38" height="11" rx="2.5"></rect><circle class="infra-led infra-led-1" cx="20" cy="19.5" r="1.7" fill="currentColor" stroke="none"></circle><circle class="infra-led infra-led-2" cx="20" cy="32.5" r="1.7" fill="currentColor" stroke="none"></circle><circle class="infra-led infra-led-3" cx="20" cy="45.5" r="1.7" fill="currentColor" stroke="none"></circle></g></svg>
        <span class="key-label">Инфраструктура</span>
        <span class="key-led" aria-hidden="true"></span>
      </button>
    </div>
  </div>
</section>
