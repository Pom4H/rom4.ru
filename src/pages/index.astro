---
import Layout from '../layouts/Layout.astro';
import SystemCircuit from '../components/SystemCircuit.astro';

const title = 'ROM4.RU — Строю и модернизирую продукты для инженерного B2B';
const description =
  'Помогаю инженерному бизнесу выпускать продукты: от первой рабочей версии до релиза. Hardware, производство, инженерные команды.';
---

<Layout title={title} description={description}>
  <div class="paper-stage">
    <main class="sheet">
      <header class="topbar" id="top">
        <a class="brand" href="#top" aria-label="ROM4.RU — на главную">ROM4.RU</a>
        <div class="brand-note">software engineering<br>и цифровые продукты</div>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Включить тёмную тему" aria-pressed="false">
          <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.4"></circle><path d="M12 2v2.6M12 19.4V22M2 12h2.6M19.4 12H22M4.9 4.9l1.9 1.9M17.2 17.2l1.9 1.9M19.1 4.9l-1.9 1.9M6.8 17.2l-1.9 1.9"></path></svg>
          <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 14.6A8.2 8.2 0 1 1 9.4 3.5a6.4 6.4 0 0 0 11.1 11.1Z"></path></svg>
        </button>
      </header>

      <section class="hero section-grid" aria-labelledby="hero-title">
        <span class="coordinate coordinate-a">A</span>
        <div class="hero-copy">
          <h1 id="hero-title">Строю и<br>модернизирую<br>продукты для<br>инженерного B2B</h1>
          <p class="lead">Помогаю бизнесу выпускать то, что раньше годами оставалось в планах. Довожу продукт от первой рабочей версии до релиза — и оставляю команде инженерную систему, которую она развивает дальше сама, без меня.</p>
          <div class="hero-actions">
            <a class="button button-primary" href="https://t.me/Pom4H" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3.4 11.3 15.9-6.1c.7-.3 1.3.2 1.1 1.1l-2.7 12.6c-.2.9-.8 1.1-1.5.7l-4.1-3-2 1.9c-.2.2-.4.4-.8.4l.3-4.2 7.7-7c.3-.3-.1-.5-.5-.2l-9.5 6-4.1-1.3c-.9-.3-.9-.9.2-1.3Z"></path></svg>
              Обсудить задачу
            </a>
          </div>
        </div>
        <div class="system-visual">
          <p class="panel-scrawl" aria-hidden="true">Дизайн вторичен—<br>важен результат</p>
          <SystemCircuit />
        </div>
      </section>

      <section class="proof ruled-section" id="proof" aria-labelledby="proof-title">
        <div class="proof-layout">
          <div class="proof-copy">
            <p class="section-label" id="proof-title">КАК Я РАБОТАЮ</p>
            <h3>Рабочая версия,<br>а не презентация</h3>
            <p>Вместо слайдов с обещаниями — первая рабочая версия, которую можно запустить и проверить на реальных людях. Гипотеза подтверждается делом, а не в обсуждении.</p>
          </div>
          <div class="proof-graphic" aria-label="Сравнение: презентация против работающего продукта">
            <figure class="proof-item proof-slide">
              <span class="proof-tag">ОБЕЩАНИЕ</span>
              <div class="slide-card" aria-hidden="true">
                <div class="slide-bar"><i></i><i></i><i></i></div>
                <div class="slide-body"><b></b><span></span><span></span><span></span></div>
                <span class="slide-foot">СЛАЙД 12 / 40</span>
                <span class="slide-stamp">ПЛАН</span>
              </div>
              <figcaption>Красивые слайды,<br>которые нельзя запустить</figcaption>
            </figure>
            <span class="proof-arrow" aria-hidden="true">→</span>
            <figure class="proof-item proof-product">
              <span class="proof-tag proof-tag-live">РЕАЛЬНОСТЬ</span>
              <div class="prod-card" aria-hidden="true">
                <div class="prod-bar"><i></i><i></i><i></i><span>app · v0.1</span></div>
                <div class="prod-main"><aside></aside><section><b></b><span></span><span></span></section></div>
                <div class="prod-foot"><b>ВЕРСИЯ 01</b><span>● В РАБОТЕ</span></div>
              </div>
              <figcaption>Продукт, который уже<br>работает у пользователей</figcaption>
            </figure>
          </div>
        </div>
      </section>

      <section class="modes ruled-section" id="modes" aria-labelledby="modes-title">
        <div class="section-intro">
          <p class="section-label" id="modes-title">С КЕМ Я РАБОТАЮ</p>
          <h2>Прихожу усилить ваш<br>бизнес, а не внедрять.</h2>
          <p>Не ставлю чужие коробки и не продаю внедрения. Строю продукты, которые делают инженерную компанию сильнее изнутри. Сам был инженером — говорю с вашей командой на одном языке.</p>
        </div>
        <div class="mode-track">
          <article class="mode">
            <span class="mode-no">01</span>
            <h3>Железо, которому нужен софт</h3>
            <p>Устройства, панели управления, телеметрия и личные кабинеты: строю цифровой продукт вокруг вашего железа.</p>
            <p class="mode-result"><i>→</i> железо + софт как один продукт</p>
          </article>
          <article class="mode">
            <span class="mode-no">02</span>
            <h3>Данные процессов — в дело</h3>
            <p>Превращаю то, что происходит в цехах и на оборудовании, в живые продукты: мониторинг, управление и решения на основе реальных данных.</p>
            <p class="mode-result"><i>→</i> видно, чем управлять</p>
          </article>
          <article class="mode">
            <span class="mode-no">03</span>
            <h3>R&amp;D и технические отделы</h3>
            <p>Внутренние инструменты и расчётные сервисы, которые ускоряют вашу разработку и снимают рутину с инженеров.</p>
            <p class="mode-result"><i>→</i> команда работает быстрее</p>
          </article>
        </div>
      </section>

      <section class="stack ruled-section" id="stack" aria-labelledby="stack-title">
        <div class="section-intro">
          <p class="section-label" id="stack-title">ТЕХНОЛОГИИ</p>
          <h2>Один инженер<br>на весь стек.</h2>
          <p>От устройства и интерфейса до бэкенда, инфраструктуры и AI — закрываю продукт целиком, без цепочки подрядчиков. Инструмент выбираю под задачу, а не по моде.</p>
        </div>
        <div class="stack-board" aria-label="Технологический стек по доменам">
          <div class="stack-bar"><span><i></i>FULL-STACK</span><span>WEB · MOBILE · IOT · BACKEND · INFRA · AI</span></div>
          <div class="stack-grid">
            <div class="stack-col" style="--cat: #bd5b31">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><rect class="draw" style="--l: 180" x="8" y="12" width="48" height="40" rx="4"></rect><path class="draw d2" style="--l: 48" d="M8 24h48"></path><circle class="pop" cx="13.5" cy="18" r="1.5" fill="currentColor" stroke="none"></circle><circle class="pop p2" cx="19.5" cy="18" r="1.5" fill="currentColor" stroke="none"></circle><path class="draw d3" style="--l: 34" d="M15 34h34"></path><path class="draw d3" style="--l: 22" d="M15 42h22"></path></g></svg>
              <b class="stack-name">Web</b>
            </div>
            <div class="stack-col" style="--cat: #164a76">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><rect class="draw" style="--l: 150" x="20" y="7" width="24" height="50" rx="5"></rect><path class="draw d2" style="--l: 8" d="M29 12h6"></path><path class="draw d3" style="--l: 14" d="M26 26h12"></path><path class="draw d3" style="--l: 10" d="M26 33h8"></path><circle class="pop p2" cx="32" cy="50" r="1.6" fill="currentColor" stroke="none"></circle></g></svg>
              <b class="stack-name">Mobile</b>
            </div>
            <div class="stack-col" style="--cat: #8f5e2f">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><rect class="draw" style="--l: 72" x="23" y="23" width="18" height="18" rx="2"></rect><rect class="draw d2" style="--l: 26" x="29" y="29" width="6" height="6" rx="1"></rect><path class="draw d2" style="--l: 110" d="M23 29H12M41 29h11M23 35H12M41 35h11M29 23V12M35 23V12M29 41v11M35 41v11"></path><circle class="pop" cx="12" cy="29" r="2" fill="currentColor" stroke="none"></circle><circle class="pop p2" cx="52" cy="35" r="2" fill="currentColor" stroke="none"></circle><circle class="pop p2" cx="35" cy="12" r="2" fill="currentColor" stroke="none"></circle><circle class="pop p3" cx="29" cy="52" r="2" fill="currentColor" stroke="none"></circle></g></svg>
              <b class="stack-name">IoT</b>
            </div>
            <div class="stack-col" style="--cat: #6e7047">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><ellipse class="draw" style="--l: 108" cx="32" cy="15" rx="17" ry="6"></ellipse><path class="draw d2" style="--l: 120" d="M15 15v30c0 3.3 7.6 6 17 6s17-2.7 17-6V15"></path><path class="draw d3" style="--l: 62" d="M15 30c0 3.3 7.6 6 17 6s17-2.7 17-6"></path><circle class="pop" cx="41" cy="44" r="1.4" fill="currentColor" stroke="none"></circle></g></svg>
              <b class="stack-name">Backend</b>
            </div>
            <div class="stack-col" style="--cat: #2f546f">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><path class="draw" style="--l: 150" d="M22 41a9 9 0 0 1-1-18 12 12 0 0 1 23-2 8 8 0 0 1 1 20Z"></path><path class="draw d2" style="--l: 40" d="M32 41v6M20 53v-6h24v6"></path><rect class="pop" x="15" y="52" width="9" height="9" rx="1.5"></rect><rect class="pop p2" x="27.5" y="52" width="9" height="9" rx="1.5"></rect><rect class="pop p3" x="40" y="52" width="9" height="9" rx="1.5"></rect></g></svg>
              <b class="stack-name">Infra</b>
            </div>
            <div class="stack-col" style="--cat: #76556f">
              <svg class="stack-icon" viewBox="0 0 64 64" aria-hidden="true"><g><path class="draw" style="--l: 150" d="M32 14C24 12 18 16 18 22C13 23 12 30 17 32C14 37 18 43 24 42C25 47 32 47 32 42"></path><path class="draw d2" style="--l: 150" d="M32 14C40 12 46 16 46 22C51 23 52 30 47 32C50 37 46 43 40 42C39 47 32 47 32 42"></path><path class="draw d3" style="--l: 30" d="M32 14V42"></path><path class="draw d3" style="--l: 12" d="M24 23c3 1 4 4 3 7"></path><path class="draw d3" style="--l: 12" d="M40 23c-3 1-4 4-3 7"></path></g></svg>
              <b class="stack-name">AI</b>
            </div>
          </div>
        </div>
      </section>

      <footer class="footer ruled-section" id="contacts">
        <div class="footer-primary">
          <p class="footer-kicker">ДАВАЙТЕ ЗАПУСТИМ ЭТО В РАБОТУ</p>
          <p class="footer-manifesto">Если у вас есть продукт, действующая система <span class="pen-mark">или идея, которую</span> пора перестать откладывать, — давайте запустим это в работу.</p>
          <div class="footer-cta-row">
            <a class="button button-primary" href="https://t.me/Pom4H" target="_blank" rel="noreferrer">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3.4 11.3 15.9-6.1c.7-.3 1.3.2 1.1 1.1l-2.7 12.6c-.2.9-.8 1.1-1.5.7l-4.1-3-2 1.9c-.2.2-.4.4-.8.4l.3-4.2 7.7-7c.3-.3-.1-.5-.5-.2l-9.5 6-4.1-1.3c-.9-.3-.9-.9.2-1.3Z"></path></svg>
              Обсудить задачу
            </a>
          </div>
        </div>
        <div class="footer-aside">
          <div class="footer-id">
            <p class="footer-signature">Роман Попов</p>
            <p class="footer-role">software engineer · AI-native builder · hands-on CTO</p>
            <div class="footer-links">
              <a class="footer-social" href="https://github.com/Pom4H" target="_blank" rel="noreferrer">github.com/Pom4H</a>
              <a class="footer-email" href="mailto:1@rom4.ru">1@rom4.ru</a>
            </div>
          </div>
          <aside class="note-card"><span>ЗАМЕТКА</span><i></i><p>Хороший продукт не нужно объяснять пользователю — он понятен в сам момент использования.</p></aside>
        </div>
        <div class="footer-bottom">
          <div class="footer-meta">
            <span>SOFTWARE ENGINEERING · ЦИФРОВЫЕ ПРОДУКТЫ</span>
            <span class="footer-year">© 2012—2026</span>
          </div>
          <div class="footer-end">
            <a href="#top">НАВЕРХ ↑</a>
            <div class="footer-rev" aria-label="Версия сайта"><b>REV. 4.0</b><time datetime="2026-07-20">20/07/2026</time></div>
          </div>
        </div>
      </footer>
    </main>
  </div>
</Layout>

<style is:global>
  :root {
      color-scheme: light;
      --page-bg: #c5c3bd;
      --paper: #f0efe8;
      --ink: #141915;
      --ink-rgb: 20,25,21;
      --hi-rgb: 255,255,255;
      --rust: #bd5b31;
      --blue: #113653;
      --ease-snap: cubic-bezier(.2,.82,.2,1);
      --ease-reveal: cubic-bezier(.22,.68,.24,1);
      --blue-2: #164a76;
      --muted: #62645e;
      --pos: #2f6b45;
      --bar: #d0d1ca;
      --sel-bg: #bf5d30;
      --sel-fg: #fffdf5;
      --panel-fill-rgb: 240,239,232;
      --panel-fill-hi-rgb: 248,246,238;
    }
    :root[data-theme='dark'] {
      color-scheme: dark;
      --page-bg: #06090b;
      --paper: #0f1518;
      --ink: #e7ede9;
      --ink-rgb: 197,210,206;
      --hi-rgb: 235,245,240;
      --rust: #ec8a5c;
      --blue: #2b6fb2;
      --blue-2: #7fb6e6;
      --muted: #939d97;
      --pos: #62c98d;
      --bar: #37413f;
      --sel-bg: #ec8a5c;
      --sel-fg: #0f1518;
      --panel-fill-rgb: 31,41,37;
      --panel-fill-hi-rgb: 44,56,51;
    }

    :root {
      --font-sans: 'Inter Variable', Inter, Arial, sans-serif;
      --font-serif: 'Iowan Old Style', 'Baskerville', 'Times New Roman', serif;
      --font-mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
      --font-hand: 'Bradley Hand', 'Iowan Old Style', cursive, serif;
      --text-micro: 10px;
      --text-sm: 12px;
      --text-md: 14px;
      --text-label: 15px;
      --text-btn: 12px;
      --lh-body: 1.65;
      --lh-tight: .98;
      --track-label: .04em;
      --track-display: -.035em;
    }

    * { box-sizing: border-box; }
    html { background: var(--page-bg); }
    body { margin: 0; overflow-x: clip; color: var(--ink); background: var(--page-bg); font-family: var(--font-sans); font-size: var(--text-md); line-height: var(--lh-body); -webkit-overflow-scrolling: touch; }
    button, select { font: inherit; }
    ::selection { background: var(--sel-bg); color: var(--sel-fg); }
    a { color: var(--rust); }
    a:hover { color: var(--blue-2); }

    .paper-stage { position: relative; width: min(1440px, calc(100% - 44px)); margin: 18px auto 25px; }

    .sheet {
      position: relative; width: 100%; margin: 0; overflow-x: clip; overflow-y: visible;
      background-color: var(--paper);
      background-image:
        radial-gradient(ellipse at 82% 39%, rgba(var(--hi-rgb),.28), transparent 40%),
        linear-gradient(90deg, rgba(39,54,55,.016) 1px, transparent 1px),
        linear-gradient(rgba(39,54,55,.013) 1px, transparent 1px);
      background-size: 100% 100%, 31px 31px, 31px 31px;
      box-shadow:
        0 1px 2px rgba(25,25,23,.05),
        0 10px 28px rgba(25,25,23,.08),
        0 28px 56px rgba(25,25,23,.1),
        inset 0 0 1px rgba(42,47,45,.5);
      border: 1px solid rgba(49,54,51,.28);
    }

    .sheet::before, .sheet::after { content: '+'; position: absolute; z-index: 5; top: 3px; color: var(--muted); font: 16px/1 var(--font-mono); }
    .sheet::before { left: 7px; }
    .sheet::after { right: 7px; }

    .topbar {
      height: 86px; padding: 0 56px; display: grid; grid-template-columns: auto 1fr auto;
      align-items: stretch; gap: 22px 30px; border-bottom: 1px solid rgba(var(--ink-rgb),.36);
      background-color: var(--paper);
      background-image: linear-gradient(90deg, rgba(var(--ink-rgb),.03) 1px, transparent 1px), linear-gradient(rgba(var(--ink-rgb),.025) 1px, transparent 1px);
      background-size: 31px 31px;
    }
    .brand {
      color: var(--ink); text-decoration: none; font-family: var(--font-mono); font-size: 28px; font-weight: 700;
      letter-spacing: .02em; white-space: nowrap; display: flex; align-items: center;
    }
    .brand-note {
      justify-self: start; align-self: stretch; display: flex; flex-direction: column; justify-content: center;
      min-width: 0; margin: 0; padding-left: 24px;
      border-left: 1px solid rgba(var(--ink-rgb),.36);
      font-family: var(--font-mono); font-size: var(--text-micro); letter-spacing: var(--track-label); line-height: 1.4;
      text-transform: uppercase; color: var(--muted);
    }
    .theme-toggle {
      justify-self: end; align-self: center; width: 42px; height: 42px; display: grid; place-items: center; padding: 0; color: var(--ink);
      background: transparent; border: 1px solid rgba(var(--ink-rgb),.5); cursor: pointer;
      transition: color .25s ease, border-color .25s ease, background-color .25s ease, transform .25s ease;
    }
    .theme-toggle:hover { color: var(--rust); border-color: var(--rust); }
    .theme-toggle:focus-visible { color: var(--rust); border-color: var(--rust); outline: none; box-shadow: 0 0 0 2px var(--paper), 0 0 0 4px var(--rust); }
    .theme-toggle:active { transform: scale(.92); }
    .theme-toggle svg { width: 19px; height: 19px; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; grid-area: 1 / 1; transition: transform .4s cubic-bezier(.2,.82,.2,1), opacity .3s ease; }
    .theme-toggle .icon-moon { opacity: 0; transform: rotate(-40deg) scale(.6); }
    .theme-toggle .icon-sun { opacity: 1; transform: rotate(0) scale(1); }
    :root[data-theme='dark'] .theme-toggle .icon-sun { opacity: 0; transform: rotate(40deg) scale(.6); }
    :root[data-theme='dark'] .theme-toggle .icon-moon { opacity: 1; transform: rotate(0) scale(1); }

    /* theme swap is instant — animating colors across the whole textured DOM was the bottleneck */
    html.theme-anim .theme-toggle svg { transition: transform .3s var(--ease-snap), opacity .2s ease; }

    .brand-note, .revision { font-family: var(--font-mono); font-size: var(--text-micro); letter-spacing: var(--track-label); line-height: 1.4; }
    .revision { border: 1px solid rgba(var(--ink-rgb),.5); padding: 8px 12px; display: grid; gap: 2px; }
    .revision time { font-size: var(--text-micro); }

    .section-grid { display: grid; grid-template-columns: 43% 57%; }
    .hero { position: relative; min-height: 850px; border-bottom: 1px solid rgba(var(--ink-rgb),.45); }
    .hero::after, .ruled-section::after { content: '+'; position: absolute; right: 9px; bottom: -8px; font: 14px/1 var(--font-mono); background: var(--paper); color: var(--muted); }
    .coordinate { position: absolute; z-index: 2; left: 17px; top: 28px; font: 13px/1 var(--font-mono); color: var(--muted); }

    .hero-copy { padding: 48px 30px 48px 74px; align-self: center; }
    h1 { margin: 0; max-width: 630px; font-family: var(--font-serif); font-size: clamp(52px, 5vw, 78px); line-height: .94; font-weight: 400; letter-spacing: var(--track-display); }
    .lead { max-width: 535px; margin: 34px 0 0; font-size: var(--text-md); line-height: var(--lh-body); }
    .hero-actions { display: flex; gap: 22px; margin-top: 42px; }
    .button { min-height: 58px; padding: 0 23px; display: inline-flex; align-items: center; justify-content: center; gap: 15px; border: 1px solid var(--rust); text-decoration: none; font-family: var(--font-mono); font-size: var(--text-btn); font-weight: 700; letter-spacing: .06em; text-transform: uppercase; transition: transform .2s ease, box-shadow .2s ease, background-color .2s ease; }
    .button:hover { transform: translateY(-3px); box-shadow: 0 8px 20px color-mix(in srgb, var(--rust), transparent 80%); }
    .button svg { width: 21px; fill: currentColor; }
    .button-primary { background: var(--rust); color: #fff; }
    .button-primary:hover, .button-primary:focus-visible { color: #fff; }
    .button-secondary { color: var(--ink); border-color: rgba(var(--ink-rgb),.48); min-width: 200px; }
    .button-secondary span { margin-left: auto; font-size: 20px; }

    .system-visual { position: relative; min-width: 0; height: 850px; border-left: 1px solid rgba(var(--ink-rgb),.12); }
    .panel-scrawl { position: absolute; z-index: 3; top: 40px; right: 46px; margin: 0; text-align: right; color: var(--ink); font: 400 24px/1.24 var(--font-hand); transform: rotate(-6deg); transform-origin: top right; pointer-events: none; }
