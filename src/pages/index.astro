    }
    :root[data-theme='dark'] .panel-key:hover, :root[data-theme='dark'] .panel-key:focus-visible, :root[data-theme='dark'] .panel-key[aria-pressed='true'] { color: color-mix(in srgb, var(--key-accent), white 42%); }
    :root[data-theme='dark'] .panel-key[aria-pressed='true'] { background: color-mix(in srgb, var(--key-accent) 16%, var(--panel-paper)); box-shadow: 0 0 0 1px color-mix(in srgb, var(--key-accent), white 30%), 0 0 20px color-mix(in srgb, var(--key-accent), transparent 66%); }
    :root[data-theme='dark'] .panel-key:hover, :root[data-theme='dark'] .panel-key:focus-visible { box-shadow: 0 0 0 1px color-mix(in srgb, var(--key-accent), white 20%); }
    :root[data-theme='dark'] .ping-core { background: color-mix(in srgb, var(--screen-accent), white 34%); box-shadow: 0 0 6px color-mix(in srgb, var(--screen-accent), transparent 40%); }
    :root[data-theme='dark'] .ping-ring { border-color: color-mix(in srgb, var(--screen-accent), white 34%); }
</style>

<script is:inline>
  (function () {
    function init() {
      const root = document.documentElement;
      root.classList.add('js');
      const meta = document.querySelector('meta[name="theme-color"]');

      try {
        const stored = localStorage.getItem('theme');
        const theme = (stored === 'light' || stored === 'dark') ? stored
          : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        root.setAttribute('data-theme', theme);
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#0f1518' : '#f0efe8');
      } catch (e) { root.setAttribute('data-theme', 'light'); }

      let animTimer = 0;
      const toggles = document.querySelectorAll('[data-theme-toggle]');
      const syncToggles = (t) => toggles.forEach((b) => {
        b.setAttribute('aria-pressed', t === 'dark' ? 'true' : 'false');
        b.setAttribute('aria-label', t === 'dark' ? 'Включить светлую тему' : 'Включить тёмную тему');
      });
      const setTheme = (t, persist) => {
        root.classList.add('theme-anim');
        root.setAttribute('data-theme', t);
        if (meta) meta.setAttribute('content', t === 'dark' ? '#0f1518' : '#f0efe8');
        if (persist) { try { localStorage.setItem('theme', t); } catch (e) {} }
        syncToggles(t);
        clearTimeout(animTimer);
        animTimer = setTimeout(() => root.classList.remove('theme-anim'), 240);
      };
      syncToggles(root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light');
      toggles.forEach((btn) => btn.addEventListener('click', () => {
        setTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark', true);
      }));
      try {
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
          if (!localStorage.getItem('theme')) setTheme(e.matches ? 'dark' : 'light', false);
        });
      } catch (e) {}

      const revealSelector = '.system-visual,.section-intro,.direction-card,.result-card,.proof-copy,.proof-graphic,.mode,.stack-col,.method-manifesto,.method-track article,.footer-primary,.footer-aside';
      const revealTargets = Array.from(document.querySelectorAll(revealSelector));
      const revealAll = () => revealTargets.forEach((el) => el.classList.add('is-in'));
      const revealIfPassed = (el) => {
        const top = el.getBoundingClientRect().top;
        if (top < window.innerHeight * 0.92) el.classList.add('is-in');
      };
      try {
        ['.direction-stack .direction-card', '.result-grid .result-card', '.mode-track .mode', '.stack-grid .stack-col', '.method-track article', '.footer-primary, .footer-aside'].forEach((sel) => {
          document.querySelectorAll(sel).forEach((el, i) => el.style.setProperty('--reveal-i', String(i)));
        });
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion || !('IntersectionObserver' in window)) {
          revealAll();
        } else {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) { entry.target.classList.add('is-in'); io.unobserve(entry.target); }
            });
          }, { rootMargin: '0px 0px -4% 0px', threshold: 0.02 });
          revealTargets.forEach((el) => {
            revealIfPassed(el);
            if (!el.classList.contains('is-in')) io.observe(el);
          });
          setTimeout(() => revealTargets.forEach(revealIfPassed), 1200);
        }
      } catch (e) { revealAll(); }

      document.querySelectorAll('[data-system-panel]').forEach((panel) => {
        const keys = Array.from(panel.querySelectorAll('[data-panel-key]'));
        const rIndex = panel.querySelector('[data-readout-index]');
        const rLabel = panel.querySelector('[data-readout-label]');
        const rTitle = panel.querySelector('[data-readout-title]');
        const rDetail = panel.querySelector('[data-readout-detail]');
        const screen = panel.querySelector('[data-panel-readout]');
        const showReadout = (key) => {
          panel.dataset.active = key.dataset.panelKey;
          if (key.dataset.accent) panel.style.setProperty('--screen-accent', key.dataset.accent);
          if (rIndex) rIndex.textContent = key.dataset.index || '';
          if (rLabel) rLabel.textContent = key.dataset.label || '';
          if (rTitle) rTitle.textContent = key.dataset.title || '';
          if (rDetail) rDetail.textContent = key.dataset.detail || '';
          if (screen) { screen.classList.remove('is-switching'); void screen.offsetWidth; screen.classList.add('is-switching'); }
        };
        const playIcon = (key) => {
          const els = key.querySelectorAll('.key-icon *');
          els.forEach((el) => { el.style.animation = 'none'; });
          void key.offsetWidth;
          els.forEach((el) => { el.style.animation = ''; });
        };
        let userPicked = false;
        keys.forEach((key) => key.addEventListener('click', () => {
          userPicked = true;
          const on = key.getAttribute('aria-pressed') === 'true';
          if (on) {
            key.setAttribute('aria-pressed', 'false');
          } else {
            key.setAttribute('aria-pressed', 'true');
            showReadout(key);
            playIcon(key);
          }
        }));
        const first = keys[0];
        if (first) showReadout(first);
        const boot = () => {
          if (userPicked) return;
          first.setAttribute('aria-pressed', 'true');
          showReadout(first);
          playIcon(first);
        };
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const board = panel.querySelector('.board-shell');
        if (!first) {
          /* nothing */
        } else if (reduce || !('IntersectionObserver' in window) || !board) {
          boot();
        } else {
          let booted = false;
          const runBoot = () => {
            if (booted) return;
            booted = true;
            setTimeout(boot, 450);
          };
          const io2 = new IntersectionObserver((ents) => {
            ents.forEach((e) => { if (e.isIntersecting) { io2.unobserve(e.target); runBoot(); } });
          }, { threshold: 0.35 });
          io2.observe(board);
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
