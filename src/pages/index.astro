    .stack-board { position: relative; margin: 34px 36px; padding: 0; border: 1px solid rgba(var(--ink-rgb),.38); background-image: linear-gradient(90deg, rgba(var(--ink-rgb),.04) 1px, transparent 1px), linear-gradient(rgba(var(--ink-rgb),.035) 1px, transparent 1px); background-size: 24px 24px; overflow: hidden; }
