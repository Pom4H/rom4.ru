---
import Layout from '../layouts/Layout.astro';
import SystemCircuit from '../components/SystemCircuit.astro';

const resultCards = [
  {
    className: 'product-result',
    kicker: 'Новый продукт',
    title: 'Рабочая версия вместо презентации',
    description: 'Интерфейс, данные, бизнес-логика и связи с другими системами соединены в один сценарий, который уже можно дать пользователям.',
    result: 'Гипотеза проверяется на реальном продукте, а не в бесконечном обсуждении.',
  },
  {
    className: 'modernization-result',
    kicker: 'Действующая система',
    title: 'Обновление без остановки бизнеса',
    description: 'Функции обновляются по частям: сначала фиксируется текущее поведение, затем изменения проверяются и постепенно включаются в работу.',
    result: 'Новые возможности появляются быстрее, а действующая система продолжает обслуживать бизнес.',
  },
  {
    className: 'git-result',
    kicker: 'Git и выпуск',
    title: 'От решения до выпуска — одна история',
    description: 'Продуктовая задача связывается с веткой, изменением кода, проверкой и конкретной версией продукта.',
    result: 'Бизнес видит, где находится изменение, что уже готово и почему принято каждое решение.',
  },
  {
    className: 'context-result',
    kicker: 'Контекст проекта',
    title: 'Решения остаются рядом с кодом',
    description: 'Описание продукта, архитектурные решения и договорённости хранятся в репозитории и меняются вместе с системой.',
    result: 'Команда понимает не только что сделано, но и почему система устроена именно так.',
  },
  {
    className: 'integration-result',
    kicker: 'Связи между системами',
    title: 'Ручные передачи исчезают',
    description: 'Продукт, CRM, ERP и другие системы обмениваются данными автоматически, а исключения остаются видимыми.',
    result: 'Меньше копирования между системами, потерянных статусов и зависимости от отдельных людей.',
  },
  {
    className: 'leadership-result',
    kicker: 'Работа с командой',
    title: 'Команда может продолжить без меня',
    description: 'Архитектура, приоритеты и инженерные практики фиксируются в коде, документации и повседневном процессе разработки.',
    result: 'У бизнеса остаётся управляемая система и команда, которая может двигать её вперёд сама.',
  },
];
---

<Layout
  title="Роман Попов — цифровые продукты для инженерного B2B"
  description="Software engineer и hands-on CTO. Помогаю инженерным B2B-компаниям запускать цифровые продукты и обновлять действующие системы."
>
  <div class="paper-stage">
  <main class="sheet">
    <div class="paper-patina" aria-hidden="true"></div>
    <header class="topbar" id="top">
      <a class="brand" href="#top" aria-label="ROM4.RU — на главную">ROM4.RU</a>
      <div class="brand-note">software engineering<br />и цифровые продукты</div>
      <nav aria-label="Основная навигация">
        <a href="#approach">подход</a>
        <a href="#artifacts">результаты</a>
        <a href="#about">как работаю</a>
        <a href="#contacts">контакты</a>
      </nav>
      <div class="revision" aria-label="Версия сайта">
        <span>REV. 4.0</span>
        <time datetime="2026-07-20">20/07/2026</time>
      </div>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Включить тёмную тему" aria-pressed="false">
        <svg class="icon-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.4" /><path d="M12 2v2.6M12 19.4V22M2 12h2.6M19.4 12H22M4.9 4.9l1.9 1.9M17.2 17.2l1.9 1.9M19.1 4.9l-1.9 1.9M6.8 17.2l-1.9 1.9" /></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 14.6A8.2 8.2 0 1 1 9.4 3.5a6.4 6.4 0 0 0 11.1 11.1Z" /></svg>
      </button>
    </header>

    <section class="hero section-grid" aria-labelledby="hero-title">
      <span class="coordinate coordinate-a">A</span>
      <div class="hero-copy">
        <h1 id="hero-title">Строю и<br />модернизирую<br />продукты для<br />инженерного B2B</h1>
        <p class="lead">
          Помогаю превратить идею или накопившуюся инженерную проблему в продукт,
          который можно выпускать и развивать. Новые сервисы, обновления действующих систем
          и внутренние продукты проходят один понятный путь: от задачи к коду, Git и выпуску.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="https://t.me/Pom4H" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3.4 11.3 15.9-6.1c.7-.3 1.3.2 1.1 1.1l-2.7 12.6c-.2.9-.8 1.1-1.5.7l-4.1-3-2 1.9c-.2.2-.4.4-.8.4l.3-4.2 7.7-7c.3-.3-.1-.5-.5-.2l-9.5 6-4.1-1.3c-.9-.3-.9-.9.2-1.3Z" /></svg>
            Обсудить задачу
          </a>
          <a class="button button-secondary" href="#approach">Что могу сделать <span>→</span></a>
        </div>
      </div>

      <div class="system-visual">
        <SystemCircuit />
      </div>
    </section>

    <section class="approach ruled-section" id="approach" aria-labelledby="approach-title">
      <div class="section-intro">
        <p class="section-label" id="approach-title">КУДА НАПРАВИТЬ<br />ИНЖЕНЕРНОЕ УСИЛИЕ</p>
        <h2>Не большой план на годы,<br />а одно конкретное изменение.</h2>
        <p>Точка входа может быть разной. Принцип один: быстро сделать первую полезную версию, встроить её в работу компании и оставить команде понятную систему для дальнейшего развития.</p>
      </div>

      <div class="direction-stack">
        <article class="direction-card build-direction">
          <div class="direction-copy">
            <span class="direction-no">01</span>
            <p class="direction-kicker">01 / НОВЫЙ ПРОДУКТ</p>
            <h3>Из идеи — в продукт,<br />которым уже пользуются</h3>
            <p>Нахожу главный сценарий, соединяю интерфейс, данные, логику и нужные системы. Первую версию сразу строю как основу, а не одноразовый макет.</p>
          </div>
          <div class="build-canvas" aria-label="Схема запуска нового цифрового продукта">
            <div class="canvas-bar"><span>ПРОДУКТ / ВЕРСИЯ 01</span><i></i><i></i><i></i></div>
            <div class="release-rail"><b>ИДЕЯ</b><span></span><b>ПРОВЕРКА</b><span></span><b class="is-live">В РАБОТЕ</b></div>
            <div class="product-window">
              <aside><i></i><i></i><i></i><i></i></aside>
              <div><span>ПЕРВАЯ РАБОЧАЯ ВЕРСИЯ</span><strong>Найти → выбрать → запустить</strong><p>ИНТЕРФЕЙС · ДАННЫЕ · ЛОГИКА · GIT</p></div>
            </div>
            <div class="canvas-note"><span>РАННИЙ ЗАПУСК</span><b>Проверить на реальной работе</b></div>
          </div>
        </article>

        <article class="direction-card modernize-direction">
          <div class="migration-map" aria-label="Карта постепенного обновления действующей системы">
            <div class="map-caption"><span>ПЛАН ОБНОВЛЕНИЯ / РЕД. 04</span><b>сейчас → после обновления</b></div>
            <div class="map-ruler" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></div>
            <div class="map-track">
              <div class="map-node current-node"><span>01</span><b>ДЕЙСТВУЮЩАЯ<br />СИСТЕМА</b><small>работает сейчас</small></div>
              <i class="map-conn" aria-hidden="true"></i>
              <div class="map-node interface-node"><span>02</span><b>ГРАНИЦЫ</b><small>что меняем</small></div>
              <i class="map-conn" aria-hidden="true"></i>
              <div class="map-node data-node"><span>03</span><b>ДАННЫЕ</b><small>как переносим</small></div>
              <i class="map-conn" aria-hidden="true"></i>
              <div class="map-node next-node"><span>04</span><b>ОБНОВЛЁННАЯ<br />СИСТЕМА</b><small>новые возможности</small></div>
            </div>
            <div class="migration-status"><span>ПРОВЕРКИ&nbsp; ✓</span><span>МОНИТОРИНГ&nbsp; ✓</span><span>ВОЗВРАТ&nbsp; ✓</span></div>
          </div>
          <div class="direction-copy">
            <span class="direction-no">02</span>
            <p class="direction-kicker">02 / ОБНОВЛЕНИЕ СИСТЕМЫ</p>
            <h3>Старое не мешает<br />выпускать новое</h3>
            <p>Не переписываю всё вслепую. Сначала проверками фиксирую границы и текущее поведение системы, планирую перенос данных и безопасный возврат. Только затем заменяю части системы небольшими контролируемыми шагами.</p>
          </div>
        </article>

        <article class="direction-card git-direction">
          <div class="direction-copy">
            <span class="direction-no">03</span>
            <p class="direction-kicker">03 / ВЫПУСК И ДОСТАВКА</p>
            <h3>Изменение доезжает<br />до пользователя само</h3>
            <p>Каждый коммит проходит один автоматический конвейер: сборка, тесты, аудит зависимостей и превью-окружение для ревью. В продакшен — контролируемым выкатом (canary) с быстрым откатом. История решений и контроль остаются у команды.</p>
          </div>
          <div class="git-console" aria-label="Современный CI/CD-конвейер: от коммита до продакшена">
            <div class="console-bar"><span><i></i> main · 7c4d1a2</span><span>КОНВЕЙЕР · PASSING</span></div>
            <div class="git-flow">
              <div><span>01</span><b>КОММИТ</b><small>feat/product</small><em>✓ запушено</em></div><i>→</i>
              <div><span>02</span><b>CI</b><small>сборка · тесты · аудит</small><em>✓ 2:41</em></div><i>→</i>
              <div><span>03</span><b>ПРЕВЬЮ</b><small>preview-окружение</small><em>✓ ревью</em></div><i>→</i>
              <div class="is-live"><span>04</span><b>ПРОД</b><small>canary → 100%</small><em>● выкат</em></div>
            </div>
            <div class="trace-list">
              <p><span>линт · типы · формат</span><b>0:11</b><i>✓</i></p>
              <p><span>юнит-тесты · 148</span><b>0:26</b><i>✓</i></p>
              <p><span>e2e · playwright</span><b>1:52</b><i>✓</i></p>
              <p><span>аудит зависимостей</span><b>0 уязвим.</b><i>✓</i></p>
            </div>
            <div class="console-metrics"><span><b>4м</b> коммит → прод</span><span><b>87%</b> покрытие</span><span><b>↩</b> откат в 1 клик</span></div>
          </div>
        </article>
      </div>
    </section>

    <section class="results ruled-section" id="artifacts" aria-labelledby="artifacts-title">
      <div class="section-intro results-intro">
        <p class="section-label" id="artifacts-title">ЧТО ОСТАЁТСЯ<br />У БИЗНЕСА</p>
        <h2>Не набор технологий,<br />а новая способность команды.</h2>
        <p>Каждый результат должен менять повседневную работу: ускорять выпуск, убирать ручной труд, открывать знания или давать команде контроль над сложной системой.</p>
      </div>

      <div class="result-grid">
        {resultCards.map((card, index) => (
          <article class:list={['result-card', card.className]}>
            <div class="result-heading"><span>0{index + 1}</span><p>{card.kicker}</p></div>
            <h3>{card.title}</h3>
            <p class="result-description">{card.description}</p>

            {index === 0 && <div class="result-ui"><div><i></i><i></i><i></i></div><aside></aside><section><span></span><span></span><span></span></section><footer><b>ВЕРСИЯ 01</b><span>В РАБОТЕ</span></footer></div>}
            {index === 1 && <div class="result-migration"><span>СЕЙЧАС</span><i>→</i><span>ПО ЧАСТЯМ</span><i>→</i><span>ОБНОВЛЕНО</span><p><b style="width: 72%"></b></p><small>72% запланированных функций обновлено</small></div>}
            {index === 2 && <div class="result-trace"><p><span>01</span> задача #1842 <b>в плане</b></p><p><span>02</span> ветка продукта <b>в работе</b></p><p><span>03</span> проверка кода <b>принято</b></p><p><span>04</span> версия 4.0 <b>выпущено</b></p></div>}
            {index === 3 && <div class="result-context"><label>КОНТЕКСТ В РЕПОЗИТОРИИ <span>↳</span></label><p>README.md <small>актуально</small></p><p>docs/decisions/ <small>28</small></p><p>architecture/ <small>ред. 7</small></p></div>}
            {index === 4 && <div class="result-route"><span>ЗАЯВКА</span><i>→</i><span>СИСТЕМА</span><i>→</i><span>ПРОДУКТ</span><i>→</i><span>КЛИЕНТ</span><small>данные · статус · исключения · история</small></div>}
            {index === 5 && <div class="result-handoff"><span><b>КОД</b><i>✓</i></span><span><b>GIT</b><i>✓</i></span><span><b>РЕШЕНИЯ</b><i>✓</i></span><span><b>КОМАНДА</b><i>✓</i></span></div>}

            <div class="result-outcome"><span>ИЗМЕНЕНИЕ</span><p>{card.result}</p></div>
          </article>
        ))}
      </div>
    </section>

    <section class="method ruled-section" id="about" aria-labelledby="method-title">
      <div class="section-intro method-intro">
        <p class="section-label" id="method-title">КАК УСТРОЕНА<br />МОЯ РАБОТА</p>
        <h2>Вхожу в задачу как инженер<br />и отвечаю за движение целиком.</h2>
        <p>От продуктового решения до кода и запуска в работу. Не отделяю стратегию от реализации: важные ограничения видно только тогда, когда работаешь с системой руками.</p>
      </div>
      <div class="method-layout">
        <aside class="method-manifesto">
          <p>РАБОТАЮ ВНУТРИ КОМАНДЫ</p>
          <h3>Думаю вместе<br />с бизнесом.<br />Строю вместе<br />с командой.</h3>
          <p>Моя роль — соединить продукт, архитектуру и разработку так, чтобы решения начали выпускаться, а не оставались на схеме.</p>
          <div><span>ПРОДУКТ</span><span>КОД</span><span>GIT</span><span>КОМАНДА</span></div>
        </aside>
        <div class="method-track">
          <article>
            <span class="method-no">01</span>
            <div><h3>Фиксирую цель и ограничения</h3><p>До реализации определяю границы системы, данные, риски, требования безопасности и поведение на случай сбоя.</p></div>
            <b>ГРАНИЦЫ</b>
          </article>
          <article>
            <span class="method-no">02</span>
            <div><h3>Делаю первую рабочую версию</h3><p>Внутри заданных границ соединяю интерфейс, данные, бизнес-логику и связи с другими системами. Проверки и защитные механизмы появляются вместе с первым кодом.</p></div>
            <b>СОЗДАНИЕ</b>
          </article>
          <article>
            <span class="method-no">03</span>
            <div><h3>Выпускаю и проверяю в работе</h3><p>Автоматические проверки, метрики и возможность возврата подтверждают, что система после запуска ведёт себя так, как было задумано.</p></div>
            <b>ВЫПУСК</b>
          </article>
          <article>
            <span class="method-no">04</span>
            <div><h3>Передаю команде контроль</h3><p>Фиксирую решения, передаю код и доступы, обучаю людей и оставляю понятный маршрут, что делать дальше.</p></div>
            <b>ПЕРЕДАЧА</b>
          </article>
        </div>
      </div>
    </section>

    <footer class="footer ruled-section" id="contacts">
      <div class="footer-primary">
        <p class="footer-manifesto">Если у вас есть продукт, действующая система или идея, которую пора перестать откладывать, — давайте запустим это в работу.</p>
        <div class="footer-cta-row">
          <a class="button button-primary" href="https://t.me/Pom4H" target="_blank" rel="noreferrer">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m3.4 11.3 15.9-6.1c.7-.3 1.3.2 1.1 1.1l-2.7 12.6c-.2.9-.8 1.1-1.5.7l-4.1-3-2 1.9c-.2.2-.4.4-.8.4l.3-4.2 7.7-7c.3-.3-.1-.5-.5-.2l-9.5 6-4.1-1.3c-.9-.3-.9-.9.2-1.3Z" /></svg>
            Обсудить задачу
          </a>
          <div class="footer-links">
            <a href="mailto:1@rom4.ru">1@rom4.ru</a>
            <a href="https://github.com/Pom4H" target="_blank" rel="noreferrer">github.com/Pom4H</a>
            <a href="https://t.me/Pom4H" target="_blank" rel="noreferrer">t.me/Pom4H</a>
          </div>
        </div>
        <p class="footer-trust">В ПРОФЕССИИ С 2017 · РАБОТАЮ УДАЛЁННО ПО ВСЕМУ МИРУ</p>
      </div>
      <div class="footer-aside">
        <div class="footer-id">
          <a class="brand" href="#top">ROM4.RU</a>
          <p>Роман Попов · software engineer<br />AI-native builder · hands-on CTO</p>
        </div>
        <aside class="note-card"><span>ЗАМЕТКА</span><i></i><p>Хорошая система помогает команде выпускать изменения чаще и понимать, что произошло в каждой версии.</p></aside>
      </div>
      <div class="footer-bottom"><span>SOFTWARE ENGINEERING · ЦИФРОВЫЕ ПРОДУКТЫ</span><span>© 2017—2026 Роман Попов</span><a href="#top">НАВЕРХ ↑</a></div>
    </footer>
  </main>
  </div>

</Layout>

<script>
  const root = document.documentElement;
  const meta = document.querySelector('meta[name="theme-color"]');
  const toggles = document.querySelectorAll('[data-theme-toggle]');
  let animTimer = 0;
  function syncToggles(t: string) {
    toggles.forEach((b) => {
      b.setAttribute('aria-pressed', t === 'dark' ? 'true' : 'false');
      b.setAttribute('aria-label', t === 'dark' ? 'Включить светлую тему' : 'Включить тёмную тему');
    });
  }
  function setTheme(t: string, persist: boolean) {
    root.classList.add('theme-anim');
    root.setAttribute('data-theme', t);
    if (meta) meta.setAttribute('content', t === 'dark' ? '#0f1518' : '#f0efe8');
    if (persist) { try { localStorage.setItem('theme', t); } catch (e) {} }
    syncToggles(t);
    window.clearTimeout(animTimer);
    animTimer = window.setTimeout(() => root.classList.remove('theme-anim'), 440);
  }
  syncToggles(root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light');
  toggles.forEach((btn) => {
    btn.addEventListener('click', () => {
      setTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark', true);
    });
  });
  try {
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) setTheme(e.matches ? 'dark' : 'light', false);
    });
  } catch (e) {}

  // ===== Reveal on scroll =====
  const revealSelector = '.system-visual,.section-intro,.direction-card,.result-card,.method-manifesto,.method-track article,.footer > div,.footer > aside';
  const revealTargets = Array.from(document.querySelectorAll<HTMLElement>(revealSelector));
  const revealAll = () => revealTargets.forEach((el) => el.classList.add('is-in'));
  try {
    ['.direction-stack .direction-card', '.result-grid .result-card', '.method-track article', '.footer > div, .footer > aside'].forEach((sel) => {
      document.querySelectorAll<HTMLElement>(sel).forEach((el, i) => el.style.setProperty('--reveal-i', String(i)));
    });
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduceMotion || !('IntersectionObserver' in window)) {
      revealAll();
    } else {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      revealTargets.forEach((el) => io.observe(el));
      // Safety net: if IO somehow never fires, reveal everything after 3s
      window.setTimeout(() => revealTargets.forEach((el) => {
        if (!el.classList.contains('is-in') && el.getBoundingClientRect().top < window.innerHeight) el.classList.add('is-in');
      }), 3000);
    }
  } catch (e) { revealAll(); }
</script>

