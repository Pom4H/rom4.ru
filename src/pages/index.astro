    .panel-key[data-panel-key='technologies']:hover .chip-inner, .panel-key[data-panel-key='technologies']:focus-visible .chip-inner, .panel-key[data-panel-key='technologies'][aria-pressed='true'] .chip-inner { animation: chip-inner .42s var(--ease-snap) .22s both; }
