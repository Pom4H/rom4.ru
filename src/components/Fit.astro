---
import SectionHead from './SectionHead.astro';

const yes = [
  'компания делает оборудование, электронику, автоматику, приборы, IoT или промышленное ПО',
  'есть рабочий legacy, который нужно обновлять поэтапно, без остановки эксплуатации',
  'нужен новый software-контур вокруг физического продукта или инженерного сервиса',
  'инженеры работают в Git и могут дать доступ к человеку, который знает предметную область',
] as const;

const no = [
  'нужен только рекламный лендинг или разовая кампания',
  'хочется переписать всё с нуля без плана совместной работы со старой системой',
  'нет доступа к коду, данным и специалисту, который понимает текущую логику',
  'нужен руководитель, который не будет сам работать в репозитории и доводить изменения до релиза',
] as const;
---

<section class="section" id="fit">
  <div class="wrap">
    <SectionHead num="05" title="Где мой формат уместен" />
    <div class="cols">
      <div class="col">
        <p class="col-label pos">Подходит</p>
        <ul class="plainlist pos">
          {yes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="col">
        <p class="col-label neg">Не подходит</p>
        <ul class="plainlist">
          {no.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>