---
import SectionHead from './SectionHead.astro';

const before = [
  'сайт не объясняет, что именно продаётся',
  'заявки приходят в личную почту и теряются',
  'контакты с выставок остаются в блокнотах и личных чатах',
  'знания о продукте хранятся у двух-трёх человек',
  'руководитель вручную закрывает пробелы в продажах',
] as const;

const after = [
  'сайт, который понятен и директору, и снабженцу',
  'каждое обращение зафиксировано и видно в аналитике',
  'карта рынка: с кем вас сравнивают и какие формулировки работают',
  'база знаний, доступная команде и AI-инструментам',
  'человек внутри, который ведёт систему дальше',
] as const;
---

<section class="section" id="result">
  <div class="wrap">
    <SectionHead num="04" title="Было — стало" />
    <div class="cols">
      <div class="col">
        <p class="col-label neg">Как обычно выглядит</p>
        <ul class="plainlist">
          {before.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="col">
        <p class="col-label pos">Что остаётся после меня</p>
        <ul class="plainlist pos">
          {after.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
