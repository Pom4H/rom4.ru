    .topbar { height: auto; min-height: 76px; padding: 14px 20px; grid-template-columns: auto 1fr auto auto; gap: 12px; }
    .brand { font-size: 30px; }
    .brand-note { display: none; }
    .topbar nav { grid-column: 1 / -1; grid-row: 2; justify-content: space-between; }
    .theme-toggle { grid-column: 3; grid-row: 1; width: 38px; height: 38px; }
    .revision { grid-column: 4; grid-row: 1; }
    .section-grid { grid-template-columns: 1fr; }
    .hero { min-height: unset; }
    .hero-copy { padding: 45px 24px 20px 38px; }
    h1 { font-size: clamp(49px, 13vw, 67px); }
    .lead { font-size: 13px; }
    .hero-actions { flex-direction: column; align-items: stretch; }
    .system-visual { height: 640px; border-left: 0; }
    .section-intro { min-height: unset; padding: 34px 25px; grid-template-columns: 1fr; gap: 24px; }
    .section-intro h2 { max-width: 620px; }
    .section-intro > p:last-child { max-width: 620px; margin-top: 0; }
    .direction-card { min-height: unset; grid-template-columns: 1fr; }
    .direction-copy { min-height: 390px; padding: 65px 34px 46px; border: 0 !important; border-bottom: 1px solid rgba(var(--ink-rgb),.2) !important; }
    .modernize-direction .direction-copy { order: -1; }
    .build-canvas, .migration-map, .git-console { min-height: 470px; margin: 24px; }
    .git-flow { gap: 6px; }
    .result-grid { padding-inline: 16px; }
    .product-result, .modernization-result, .git-result, .context-result, .integration-result { grid-column: span 6; }
    .product-result, .leadership-result { grid-column: span 12; }
    .leadership-result { grid-template-columns: 1fr 1fr; }
    .method-layout { grid-template-columns: 1fr; }
    .method-manifesto { min-height: 520px; padding: 50px 34px; border-right: 0; border-bottom: 1px solid rgba(var(--ink-rgb),.24); }
    .method-track article { min-height: 145px; }
    .footer { grid-template-columns: 1fr; }
    .footer-primary { padding: 38px 25px; }
    .footer-aside { border-left: 0; border-top: 1px solid rgba(var(--ink-rgb),.2); padding: 34px 25px; }
    .footer-cta-row { gap: 20px; }
    .footer-cta-row .button { width: 100%; }
    .note-card { align-self: stretch; }
    .footer-bottom { grid-template-columns: 1fr 1fr; padding-inline: 25px; line-height: 1.4; }
  }

  @media (max-width: 520px) {
    .topbar nav { gap: 8px; font-size: 8px; }
    .topbar nav a:nth-child(3) { display: none; }
    .revision { padding: 6px; }
    .hero-copy { padding-left: 24px; }
    h1 { font-size: clamp(42px, 12vw, 52px); }
    .system-visual { height: 560px; }
    .direction-copy { min-height: 360px; padding-inline: 24px; }
    .direction-copy h3 { font-size: 39px; }
    .build-canvas, .migration-map, .git-console { min-height: 430px; margin: 12px; }
    .build-canvas { padding-inline: 16px; }
    .product-window { grid-template-columns: 48px 1fr; }
    .product-window > div { padding-inline: 20px; }
    .canvas-note { width: 190px; }
    .map-ruler { display: none; }
    .map-track { flex-direction: column; align-items: stretch; top: 50%; }
    .map-node { padding: 10px 12px; }
    .map-conn { flex: 0 0 16px; width: 1px; height: 16px; align-self: center; }
    .map-conn::after { content: '⌄'; right: auto; left: 50%; top: auto; bottom: -4px; transform: translateX(-50%); }
    .migration-status { gap: 7px; font-size: 6px; }
    .git-console { padding-inline: 14px; }
    .git-flow { grid-template-columns: repeat(2, 1fr); gap: 8px; padding-top: 10px; }
    .git-flow > i { display: none; }
    .git-flow > div { min-height: 74px; }
    .trace-list p { grid-template-columns: 1fr auto 54px; gap: 7px; }
    .console-metrics { left: 14px; right: 14px; }
    .result-card, .product-result, .modernization-result, .git-result, .context-result, .integration-result, .leadership-result { grid-column: span 12; min-height: 390px; }
    .leadership-result { display: flex; }
    .leadership-result .result-heading, .leadership-result h3, .leadership-result .result-description, .leadership-result .result-handoff, .leadership-result .result-outcome { grid-column: auto; grid-row: auto; }
    .result-route { gap: 3px; font-size: 6px; }
    .method-manifesto h3 { font-size: 50px; }
    .method-track article { padding: 25px 20px; grid-template-columns: 45px 1fr; gap: 15px; }
    .method-track article > b { grid-column: 2; justify-self: start; }
    .footer-bottom { grid-template-columns: 1fr; }
  }

  /* ===== Тёмная тема: поверхности, не следующие за токенами ===== */
  :global(:root[data-theme='dark']) .sheet {
    background-color: var(--paper);
    background-image:
      var(--paper-noise),
      radial-gradient(ellipse at 78% 30%, rgba(var(--hi-rgb),.045), transparent 48%),
      linear-gradient(rgba(var(--ink-rgb),.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--ink-rgb),.05) 1px, transparent 1px);
    background-size: 300px 300px, 100% 100%, 31px 31px, 31px 31px;
    background-blend-mode: soft-light, screen, normal, normal;
    box-shadow: inset 0 0 0 1px rgba(var(--ink-rgb),.14), inset 0 0 140px rgba(0,0,0,.45);
    border-color: rgba(var(--ink-rgb),.22);
  }
  :global(:root[data-theme='dark']) .paper-patina { display: none; }
  :global(:root[data-theme='dark']) .paper-stage::before,
  :global(:root[data-theme='dark']) .paper-stage::after { opacity: .5; }

  :global(:root[data-theme='dark']) .build-canvas { background: rgba(var(--hi-rgb),.03); }
  :global(:root[data-theme='dark']) .result-card { background: rgba(var(--hi-rgb),.028); }
