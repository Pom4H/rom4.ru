---
import SectionHead from './SectionHead.astro';

const before = [
  'критичная логика привязана к Windows, старому фреймворку или одному специалисту',
  'релиз зависит от ручной инструкции и конкретного рабочего компьютера',
  'оборудование, backend, интерфейс и документация развиваются отдельно',
  'новый продукт месяцами не выходит за пределы прототипа',
  'legacy страшно менять, потому что нет тестов, логов и понятной границы системы',
] as const;

const after = [
  'миграция разбита на проверяемые этапы, старый и новый контуры могут работать параллельно',
  'Linux и open-source компоненты используются там, где снижают стоимость и зависимость',
  'сборка, тесты, логи и повторяемый deploy находятся в репозитории',
  'первый вертикальный срез работает с реальными данными и интеграциями',
  'команда получает архитектуру, документацию и runbook для дальнейшей разработки',
] as const;
---

<section class="section" id="result">
  <div class="wrap">
    <SectionHead num="04" title="Что меняется в системе" />
    <div class="cols">
      <div class="col">
        <p class="col-label neg">Исходная точка</p>
        <ul class="plainlist">
          {before.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="col">
        <p class="col-label pos">После проекта</p>
        <ul class="plainlist pos">
          {after.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>