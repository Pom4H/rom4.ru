    .screen-dot { margin-left: auto; width: 6px; height: 6px; border-radius: 50%; background: color-mix(in srgb, var(--screen-accent), white 30%); box-shadow: 0 0 8px color-mix(in srgb, var(--screen-accent), transparent 35%); }
