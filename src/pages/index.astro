    .screw::after { content: ''; position: absolute; left: 1px; right: 1px; top: 3px; height: 1px; background: currentColor; transform: rotate(-18deg); }
    .screw-a { left: 18px; top: 18px; } .screw-b { right: 18px; top: 18px; } .screw-c { right: 18px; bottom: 18px; } .screw-d { left: 18px; bottom: 18px; }

    .panel-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 7px; }
    .panel-key, .reset-key, .panel-cta, .live-cell { position: relative; min-width: 0; min-height: 0; border: 1.2px solid currentColor; border-radius: 15px; background: rgba(var(--panel-fill-rgb),.82); }
