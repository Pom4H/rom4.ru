    .ping-ring { position: absolute; width: 8px; height: 8px; border: 1.4px solid var(--screen-accent, var(--panel-rust)); border-radius: 50%; opacity: 0; animation: ping 2.4s cubic-bezier(.2,.6,.3,1) infinite; }
    .ping-ring-2 { animation-delay: 1.2s; }
    @keyframes ping { 0% { transform: scale(1); opacity: .55; } 100% { transform: scale(3.6); opacity: 0; } }
    .live-label { font: 300 var(--text-micro)/1 var(--font-sans); letter-spacing: .1em; color: var(--muted); }

    .panel-cta { grid-column: span 2; padding: 0 20px; display: flex; align-items: center; justify-content: space-between; color: var(--panel-ink); text-decoration: none; font: 300 var(--text-micro)/1 var(--font-sans); letter-spacing: .08em; text-transform: uppercase; overflow: hidden; transition: color .16s ease, background-color .16s ease, box-shadow .16s ease; }
    .panel-cta span, .panel-cta b { position: relative; z-index: 1; }
