---
import SectionHead from './SectionHead.astro';

const yes = [
  'компания живёт давно и делает настоящий продукт: приборы, автоматика, электроника, заказная разработка',
  'выручка есть, но продажи держатся на старых связях',
  'есть ощущение, что сайт и процессы отстали от уровня бизнеса',
  'готовы дать доступ к инженерам и продукту',
] as const;

const no = [
  'нужен «просто красивый сайт» к выставке',
  'стартап без продукта и клиентов',
  'хочется внедрить AI, потому что все внедряют',
  'некому внутри принять систему — и искать такого человека не хочется',
] as const;
---

<section class="section" id="fit">
  <div class="wrap">
    <SectionHead num="04" title="Кому это подходит" />
    <div class="cols">
      <div class="col">
        <p class="col-label pos">Сработаемся, если</p>
        <ul class="plainlist pos">
          {yes.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="col">
        <p class="col-label neg">Не подойдёт, если</p>
        <ul class="plainlist">
          {no.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </div>
</section>
